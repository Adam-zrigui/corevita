generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  RADIOLOGIST
  ASSISTANT
  VIEWER
}

enum StudyStatus {
  PENDING
  READING
  REPORTED
}

enum ReportStatus {
  DRAFT
  FINAL
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  members      Membership[]
  studies      Study[]
  subscription Subscription?
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  reports       Report[]     @relation("ReportAuthor")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(VIEWER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Study {
  id          String       @id @default(cuid())
  tenantId    String
  studyUid    String       @unique
  patientId   String?
  patientName String?
  modality    String?
  slices      Int          @default(0)
  status      StudyStatus  @default(PENDING)
  description String?
  studyDate   String?
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  series      Series[]
  reports     Report[]
  shareTokens ShareToken[]

  @@index([tenantId, createdAt(sort: Desc)])
}

model Series {
  id            String     @id @default(cuid())
  seriesUid     String
  seriesNumber  Int?
  modality      String?
  instanceCount Int        @default(0)
  studyId       String
  study         Study      @relation(fields: [studyId], references: [id], onDelete: Cascade)
  instances     Instance[]
  createdAt     DateTime   @default(now())

  @@unique([studyId, seriesUid])
}

model Instance {
  id             String   @id @default(cuid())
  sopInstanceUid String?
  instanceNumber Int?
  storageDriver  String   @default("b2")
  storageKey     String
  filePath       String?
  seriesId       String
  series         Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  stripeId           String    @unique
  status             String    @default("incomplete")
  priceId            String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Report {
  id        String       @id @default(cuid())
  studyId   String
  authorId  String?
  status    ReportStatus @default(DRAFT)
  content   String?
  createdAt DateTime     @default(now())
  study     Study        @relation(fields: [studyId], references: [id], onDelete: Cascade)
  author    User?        @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

model ShareToken {
  id            String   @id @default(cuid())
  token         String   @unique
  studyId       String
  study         Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  password      String?
  allowDownload Boolean  @default(false)
  createdAt     DateTime @default(now())
}
