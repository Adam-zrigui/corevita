# Database (Neon Postgres)
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# Firebase Auth — Client SDK (Firebase Console → Settings → General → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Firebase Auth — Admin SDK (Project Settings → Service accounts → Firebase Admin SDK → Generate key)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@<project>.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Default tenant slug (used in development to auto-resolve the tenant)
DEFAULT_TENANT_SLUG="default"

# Storage (S3-compatible — Backblaze B2, AWS, etc.)
DICOM_STORAGE_DRIVER="b2"                   # or "s3"
DICOM_S3_BUCKET="corevita"
DICOM_S3_REGION="eu-central-003"
DICOM_S3_ENDPOINT="https://s3.eu-central-003.backblazeb2.com"
DICOM_S3_ACCESS_KEY_ID=""
DICOM_S3_SECRET_ACCESS_KEY=""

# DICOM signing secret for authenticated image URLs
# Generate with: openssl rand -hex 32
DICOM_SIGNING_SECRET=""

# DICOM URL TTL (seconds) for signed image URLs in authenticated viewer
DICOM_URL_TTL_SECONDS="900"

# Queue (Redis via Upstash) — optional; leave empty to write studies directly
REDIS_URL="rediss://default:token@host.upstash.io:6379"
DICOM_QUEUE_DRIVER="bullmq"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."           # Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook

# Stripe Price IDs (create products in Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID="price_xxxxx"
STRIPE_CLINIC_PRICE_ID="price_xxxxx"
STRIPE_ENTERPRISE_PRICE_ID="price_xxxxx"

# AI Report Generation (optional)
AI_REPORT_URL="https://api.example.com/v1/reports"
AI_REPORT_API_KEY=""

# Sentry (optional — https://sentry.io)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.0"
SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0.05"
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="0.2"
